{
  "name": "todica",
  "version": "0.0.0",
  "private": true,
  "description": "Todica モノレポルート. npm workspaces で domain / server / web を束ねる.",
  "author": "BigTree777",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BigTree777/todica.git"
  },
  "type": "module",
  "workspaces": ["domain", "server", "web"],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc -p domain/tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "android:sync": "npm run build -w web && npx cap sync android",
    "android:bundle": "npm run android:sync && cd android && ./gradlew bundleRelease",
    "clean": "rimraf -g test-results web/dev-dist .e2e-data \"**/*.tsbuildinfo\"",
    "clean:dist": "rimraf domain/dist server/dist web/dist && npm run build -w domain"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^1.9.4",
    "@hono/node-server": "^2.0.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitest/coverage-v8": "^2.1.8",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.30.1",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/preferences": "^8.0.1"
  }
}
