# Claude Code: 個人用ローカル設定（個人の許可リスト等）
.claude/settings.local.json

# Node / TypeScript / ビルド成果物
node_modules/
dist/
build/
coverage/
.tsbuildinfo
*.tsbuildinfo

# tsc が rootDir 経由でテストソース横に吐く成果物
# (vitest は .ts を直接実行するため, 同梱されると古い JS / 型宣言が混入する)
**/__tests__/**/*.js
**/__tests__/**/*.d.ts
**/__tests__/**/*.js.map
**/__tests__/**/*.d.ts.map

# 永続化機構（SQLite）/ ローカル DB
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ログ / 一時ファイル
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store

# エディタ
.vscode/
.idea/

# 環境変数
.env
.env.local

# Android 署名
android/key.properties
*.keystore
*.jks

# Android ローカル設定
android/local.properties

# Capacitor ビルドキャッシュ
android/.gradle/
android/app/build/
