# 環境変数のサンプル。これをコピーして .env を作成する（.env は Git 管理対象外）。
# 詳細は docs/developer/setup/server.md を参照。実値は決してコミットしないこと。

# リッスンポート（既定: 3000）。
PORT=3000

# SQLite データベースファイルのパス（既定: ./todica.db）。
DATABASE_PATH=./todica.db

# CORS で許可する Web / アプリのオリジン（カンマ区切り）。
# 未指定時は http://localhost:5173,capacitor://localhost を許可する。
# 本番では実際の Web オリジンに置き換える。
ALLOWED_ORIGINS=http://localhost:5173,capacitor://localhost

# --- Web クライアント (Vite) 用 ---
# VITE_ プレフィックスを持つ変数だけが Vite を通じてクライアントに expose される。
# `web/vite.config.ts` の envDir 設定によりこのファイルから読み込まれる。

# Web から呼び出すサーバの URL。
# - dev: Web (Vite :5173) と API (Hono :3000) が別オリジンになるので
#        `http://localhost:3000` を指定する必要がある。
# - 本番（nginx 等で Web と API を同一ドメイン配信する構成）: 空でよい。
#        相対パス `/api/...` がそのまま同一オリジンに解決される。
VITE_API_BASE_URL=http://localhost:3000
